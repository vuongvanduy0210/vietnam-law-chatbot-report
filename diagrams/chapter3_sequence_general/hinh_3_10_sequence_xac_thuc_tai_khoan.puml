@startuml
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName "Arial"
skinparam defaultFontSize 18
skinparam dpi 180
skinparam sequence {
  ArrowColor #111111
  ArrowThickness 1.4
  LifeLineBorderColor #111111
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #111111
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #111111
  ParticipantFontStyle bold
  ParticipantFontSize 18
  ArrowFontSize 17
  GroupFontSize 17
  BoxBorderColor #111111
  BoxBackgroundColor #FFFFFF
}
hide footbox
mainframe sd Xác thực và tài khoản

actor "Người dùng" as User
boundary "Giao diện" as UI
control "Hệ thống" as System
database "CSDL" as DB

User -> UI: 1: Nhập thông tin đăng ký hoặc đăng nhập
activate UI
UI -> UI: 2: Kiểm tra định dạng dữ liệu
UI -> System: 3: Gửi yêu cầu xác thực
activate System
System -> DB: 4: Kiểm tra hoặc tạo tài khoản
activate DB
DB --> System: 5: Trả dữ liệu người dùng
deactivate DB
System --> UI: 6: Trả token và thông tin tài khoản
deactivate System
UI --> User: 7: Chuyển vào màn hình chính

opt Cập nhật hồ sơ hoặc đổi mật khẩu
  User -> UI: 8: Nhập thông tin cần thay đổi
  UI -> System: 9: Gửi yêu cầu cập nhật
  activate System
  System -> DB: 10: Cập nhật dữ liệu tài khoản
  activate DB
  DB --> System: 11: Xác nhận đã lưu
  deactivate DB
  System --> UI: 12: Trả kết quả cập nhật
  deactivate System
  UI --> User: 13: Hiển thị trạng thái thành công
end

alt Thông tin không hợp lệ
  System --> UI: 14: Từ chối yêu cầu
  UI --> User: 15: Hiển thị lỗi xác thực
end
deactivate UI
@enduml

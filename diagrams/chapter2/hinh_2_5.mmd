%%{init: {"theme":"base","flowchart":{"nodeSpacing":25,"rankSpacing":22,"padding":8,"curve":"basis","htmlLabels":false},"themeVariables":{"fontFamily":"Arial, Helvetica, sans-serif","fontSize":"15px","primaryColor":"#ffffff","primaryTextColor":"#111111","primaryBorderColor":"#111111","secondaryColor":"#f4f4f4","tertiaryColor":"#fafafa","lineColor":"#111111","clusterBkg":"#f7f7f7","clusterBorder":"#8a8a8a","edgeLabelBackground":"#ffffff"}}}%%
flowchart TB
    IN["Input\nmessage + query"]
    THINK["Thought\nlập kế hoạch"]
    ACT["Action\ngọi tool"]
    OBS["Observation\nbằng chứng"]
    CHECK{"Đủ\nbằng chứng?"}
    RETRY["Chưa đủ\nbổ sung tìm kiếm"]
    GEN["Đủ bằng chứng\nGenerate\nanswer + sources"]

    IN --> THINK --> ACT --> OBS --> CHECK
    CHECK --> RETRY --> THINK
    CHECK --> GEN

    classDef core fill:#ffffff,stroke:#111111,stroke-width:2px,color:#111111;
    classDef decision fill:#f4f4f4,stroke:#111111,stroke-width:2px,color:#111111;
    class IN,THINK,ACT,OBS,RETRY,GEN core;
    class CHECK decision;

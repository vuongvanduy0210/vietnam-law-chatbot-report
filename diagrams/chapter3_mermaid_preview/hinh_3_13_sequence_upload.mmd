%%{init: {"theme": "base", "sequence": {"mirrorActors": false, "wrap": true, "width": 150, "height": 65, "messageMargin": 48}, "themeVariables": {"actorBkg": "#ffffff", "actorBorder": "#111111", "actorTextColor": "#111111", "signalColor": "#111111", "signalTextColor": "#111111", "activationBkgColor": "#ffffff", "activationBorderColor": "#111111", "labelBoxBkgColor": "#ffffff", "labelTextColor": "#111111", "loopTextColor": "#111111"}}}%%
sequenceDiagram
    participant Admin as Admin Web
    participant Main as Main Service
    participant PG as PostgreSQL
    participant Mongo as MongoDB
    participant RAG as RAG Service
    participant Chroma as ChromaDB

    Admin->>Main: POST /documents/upload-v2
    Main->>PG: Tạo document_tasks
    Main-->>Admin: WebSocket UPLOAD_PROGRESS
    Main->>Main: Kiểm tra file, hash, law_id
    Main->>Main: OCR, parse, validate
    Main->>Mongo: Lưu articles và laws_cache
    Main->>RAG: POST /ingest/articles
    RAG->>Chroma: Chunk, embedding, insert
    Chroma-->>RAG: success
    RAG-->>Main: ingest result
    Main->>PG: completed, progress 100
    Main-->>Admin: UPLOAD_STATUS completed
    alt lỗi sau khi ghi dữ liệu
      Main->>Mongo: Rollback articles/cache
      Main->>RAG: DELETE /ingest/articles/{law_id}
      Main->>PG: failed
      Main-->>Admin: UPLOAD_STATUS failed
    end
